# --- VNGCloud AI Platform / MAAS ---
# Bắt buộc nếu ENABLE_LLM=true. Dùng cho các bước semantic/text checks.
AI_PLATFORM_API_KEY=
AI_PLATFORM_ENDPOINT=https://maas-llm-aiplatform-hcm.api.vngcloud.vn/v1/chat/completions
AI_PLATFORM_MODEL=minimax/minimax-m2.5

# Bắt buộc cho endpoint /check/image.
# Giá trị phải là tên model multimodal/vision có hỗ trợ image input trên AI Platform.
# Không dùng minimax/minimax-m2.5 cho ảnh vì model đó là text-only.
AI_PLATFORM_VISION_MODEL=

# --- Cấu hình request gửi tới model ---
LLM_MAX_TOKENS=2000
LLM_TOP_P=0.95
LLM_PRESENCE_PENALTY=0
LLM_INSTRUCTION_ROLE=assistant
LLM_FORCE_JSON=false

# --- Optional Gemma checker ---
# Nếu không dùng Gemma thì để trống. Agent vẫn chạy với AI Platform text model.
GEMMA_API_KEY=
GEMMA_ENDPOINT=https://api.example-gemma.ai/v1/chat/completions
GEMMA_MODEL=gemma-4

# --- Agent config ---
PORT=8000
LOG_LEVEL=INFO

# Set false để chỉ chạy deterministic rules, không gọi LLM và không tốn chi phí.
ENABLE_LLM=true

# Đường dẫn skill folder khi chạy local bằng Python.
# Khi chạy Docker, Dockerfile override thành /app/content-quality-checker.
SKILL_PATH=../content-quality-checker
