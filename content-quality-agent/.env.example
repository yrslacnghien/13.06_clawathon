# --- LLM API credentials (required for semantic checks) ---
MINIMAX_API_KEY=
MINIMAX_ENDPOINT=https://api.minimax.chat/v1/chat/completions
MINIMAX_MODEL=minimax-2.5

GEMMA_API_KEY=
GEMMA_ENDPOINT=https://api.example-gemma.ai/v1/chat/completions
GEMMA_MODEL=gemma-4

# --- Agent config ---
PORT=8000
LOG_LEVEL=INFO

# Set to false for deterministic-only checking (no LLM calls, no cost)
ENABLE_LLM=true

# Path to the skill folder. Defaults to ../content-quality-checker
# In Docker this is overridden to /app/content-quality-checker
SKILL_PATH=../content-quality-checker
